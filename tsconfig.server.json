{
  "compilerOptions": {
    "target": "es2020",
    "module": "node20",
    "lib": ["es2020"],
    "outDir": "dist/server",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/server"],
  "exclude": ["node_modules", "dist"]
}
